# AI 网页翻译器环境变量配置
# 复制此文件为 .env 并填入你的实际配置

# ============================================
# 方式1: OpenClaw 格式（推荐）
# ============================================
# 支持 anthropic-messages 或 openai-compatible provider

# 在浏览器 Console 中设置：
openclaw = {
  "provider": "anthropic-messages",
  "baseUrl": "https://api.kimi.com/coding",
  "apiKey": "sk-kimi-your-api-key-here",
  "model": "kimi-for-coding"
}

# 或使用标准 JSON 格式：
KIMI_CODING_API_CONFIG={"openclaw":{"provider":"anthropic-messages","baseUrl":"https://api.kimi.com/coding","apiKey":"sk-kimi-your-key","model":"kimi-for-coding"}}

# ============================================
# 方式2: 标准格式（OpenAI Compatible）
# ============================================

# 基本配置
KIMI_API_KEY=your_api_key_here
KIMI_API_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-latest

# 或使用 JSON 格式
KIMI_CODING_API_CONFIG={"api_key":"your_key","base_url":"https://api.moonshot.cn/v1","model":"kimi-latest"}

# ============================================
# Provider 说明
# ============================================
# 
# 1. openai-compatible (默认)
#    - 适用于: Kimi, OpenAI, Azure OpenAI 等
#    - API 端点: /chat/completions
#    - 认证头: Authorization: Bearer {apiKey}
#
# 2. anthropic-messages
#    - 适用于: Claude API, 某些兼容 Anthropic 格式的服务
#    - API 端点: /v1/messages
#    - 认证头: x-api-key: {apiKey}
#    - 额外头: anthropic-version: 2023-06-01
#
# ============================================
# 在网页中使用
# ============================================
# 
# 方法1: 直接设置 window.openclaw
# window.openclaw = {
#   provider: "anthropic-messages",
#   baseUrl: "https://api.kimi.com/coding",
#   apiKey: "sk-kimi-xxx",
#   model: "kimi-for-coding"
# };
#
# 方法2: 使用 localStorage
# localStorage.setItem('openclaw', JSON.stringify({
#   provider: "anthropic-messages",
#   baseUrl: "https://api.kimi.com/coding",
#   apiKey: "sk-kimi-xxx",
#   model: "kimi-for-coding"
# }));
#
# 方法3: 使用 KIMI_CODING_API_CONFIG
# localStorage.setItem('KIMI_CODING_API_CONFIG', JSON.stringify({
#   openclaw: {
#     provider: "anthropic-messages",
#     baseUrl: "https://api.kimi.com/coding",
#     apiKey: "sk-kimi-xxx",
#     model: "kimi-for-coding"
#   }
# }));
